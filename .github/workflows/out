            - name: Upload GitHub Pages artifact
  uses: actions/upload-pages-artifact@v5.0.0
  with:
    # Artifact name
    name: # optional, default is github-pages
    # Path of the directory containing the static assets.
    path: out/ # default is _site/
    # Duration after which artifact will expire in days.
    retention-days: # optional, default is 1
    # Include hidden files and directories (those starting with a dot) in the artifact. Excludes .git and .github regardless.
    include-hidden-files: # optional, default is false
          
